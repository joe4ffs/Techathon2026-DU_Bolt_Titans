# HTTP port the backend listens on
PORT=3001

# How often (ms) the simulator ticks and broadcasts updates
TICK_INTERVAL_MS=5000

# How many simulated milliseconds pass per real millisecond.
# At 300x, roughly 5 real minutes = 1 simulated day, so office-hours
# and continuous-on alerts reliably occur within a short demo window.
SIM_SPEED_MULTIPLIER=300
